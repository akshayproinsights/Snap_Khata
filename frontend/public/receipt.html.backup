<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <!-- Force desktop view on mobile (CamScanner style) -->
    <meta name="viewport" content="width=850" />
    <title id="pageTitle">Order Summary • SnapKhata</title>

    <!-- Open Graph -->
    <meta property="og:title" id="ogTitle" content="Order Summary • SnapKhata" />
    <meta property="og:description" content="View your complete order details and receipt." />
    <meta property="og:type" content="website" />

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Noto+Sans:wght@400;600;700&display=swap"
        rel="stylesheet">

    <style>
        :root {
            --bg: #f8fafc;
            --white: #ffffff;
            --border: #e2e8f0;
            --border-strong: #94a3b8;
            --text-primary: #0f172a;
            --text-secondary: #475569;
            --text-muted: #94a3b8;
            --accent: #4f46e5;
            --accent-dark: #3730a3;
            --accent-light: #eef2ff;
            --green: #10b981;
            --green-bg: #ecfdf5;
            --green-border: #a7f3d0;
            --amber: #f59e0b;
            --amber-bg: #fffbeb;
            --amber-border: #fef3c7;
            --red: #ef4444;
            --invoice-bg: #ffffff;
            --invoice-border: #0f172a;
        }

        * {
            box-sizing: border-box;
            -webkit-font-smoothing: antialiased;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Inter', system-ui, sans-serif;
            background: var(--bg);
            color: var(--text-primary);
            line-height: 1.6;
        }

        /* ── Loader ── */
        .loader-wrap {
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 16px;
            background: var(--bg);
        }

        .spinner {
            width: 44px;
            height: 44px;
            border: 4px solid var(--border);
            border-top-color: var(--accent);
            border-radius: 50%;
            animation: spin 0.9s linear infinite;
        }

        @keyframes spin {
            to {
                transform: rotate(360deg);
            }
        }

        .loader-text {
            color: var(--text-secondary);
            font-size: 15px;
            font-weight: 500;
        }

        .loader-sub {
            color: var(--text-muted);
            font-size: 13px;
        }

        /* ── Error ── */
        .error-wrap {
            min-height: 100vh;
            display: none;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 40px 20px;
            text-align: center;
        }

        .error-icon {
            font-size: 52px;
            margin-bottom: 16px;
        }

        .error-title {
            font-size: 22px;
            font-weight: 800;
            color: var(--red);
            margin-bottom: 8px;
        }

        .error-desc {
            color: var(--text-secondary);
            max-width: 380px;
            margin-bottom: 24px;
        }

        .btn-retry {
            background: var(--accent);
            color: #fff;
            border: none;
            padding: 12px 28px;
            border-radius: 10px;
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
            font-family: inherit;
        }

        /* ── Content wrapper ── */
        #content-wrap {
            display: none;
            width: 100%;
            overflow-x: hidden;
        }
 
        
        /* ── Desktop Container ── */
        .scaled-container {
            width: 850px;
            margin: 0 auto;
            padding: 40px 0 80px;
            display: flex;
            justify-content: center;
        }

        /* ─────────────────────────────────────────────────────
           PREMIUM DOCUMENT STYLES
        ───────────────────────────────────────────────────── */
        .inv-page {
            width: 100%;
            margin: 0 auto;
        }

        .inv-doc {
            background: var(--white);
            border: 1px solid #e5e7eb;
            border-radius: 12px;
            box-shadow: 
                0 4px 6px -1px rgba(0,0,0,0.05),
                0 10px 15px -3px rgba(0,0,0,0.1),
                0 0 0 1px rgba(0,0,0,0.02);
            overflow: hidden;
            position: relative;
            min-height: 1000px;
            display: flex;
            flex-direction: column;
            color: var(--text-primary);
        }

        .inv-shop-header {
            padding: 48px 48px 32px;
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            background: #ffffff;
        }

        .inv-doc-type {
            font-size: 13px;
            font-weight: 700;
            color: var(--text-muted);
            letter-spacing: 2px;
            text-transform: uppercase;
            margin-bottom: 24px;
            display: block;
        }

        .inv-shop-name {
            font-size: 26px;
            font-weight: 800;
            color: #111827;
            letter-spacing: -0.5px;
            line-height: 1.1;
            margin-bottom: 8px;
        }

        .inv-shop-detail {
            font-size: 13px;
            color: var(--text-secondary);
            line-height: 1.6;
        }

        .inv-badge-container {
            text-align: right;
            display: flex;
            flex-direction: column;
            align-items: flex-end;
            gap: 12px;
        }

        .inv-gst-number {
            font-size: 14px;
            font-weight: 600;
            color: var(--text-primary);
            font-family: 'Noto Sans', monospace;
        }

        .inv-status-pill {
            display: inline-block;
            padding: 6px 16px;
            border-radius: 9999px;
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 0.5px;
            text-transform: uppercase;
        }

        .inv-paid {
            background: #dcfce7;
            color: #166534;
        }

        .inv-pending {
            background: #fef3c7;
            color: #b45309;
        }

        .inv-details-row {
            display: flex;
            padding: 0 48px 32px;
            justify-content: space-between;
        }
        
        .inv-details-grid {
            display: flex;
            gap: 80px;
        }

        .inv-col-label {
            font-size: 11px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: var(--text-muted);
            margin-bottom: 8px;
        }

        .inv-col-val {
            font-size: 14px;
            color: var(--text-secondary);
            line-height: 1.6;
        }

        .inv-col-val strong {
            font-weight: 600;
            color: var(--text-primary);
        }

        .inv-table-container {
            padding: 0 48px;
            flex-grow: 1;
        }

        .inv-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 13px;
        }

        .inv-table th {
            padding: 12px 8px;
            font-size: 11px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: var(--text-muted);
            border-bottom: 1px solid var(--border-strong);
            text-align: left;
        }

        .inv-table th:first-child, .inv-table td:first-child { padding-left: 0; }
        .inv-table th:last-child, .inv-table td:last-child { padding-right: 0; }

        .inv-table th.right { text-align: right; }
        .inv-table th.center { text-align: center; }

        .inv-table td {
            padding: 16px 8px;
            border-bottom: 1px solid #f1f5f9;
            color: var(--text-primary);
            vertical-align: top;
        }

        .inv-table td.right { 
            text-align: right; 
            font-variant-numeric: tabular-nums;
        }
        
        .inv-table td.center { 
            text-align: center; 
        }

        .inv-table tbody tr:last-child td {
            border-bottom: 1px solid var(--border-strong);
        }

        .inv-totals-wrap {
            display: flex;
            padding: 32px 48px;
            justify-content: space-between;
            align-items: flex-end;
        }

        .inv-amount-words {
            max-width: 320px;
            font-size: 12px;
            color: var(--text-secondary);
            background: #f8fafc;
            padding: 16px;
            border-radius: 8px;
            margin-top: 8px;
        }
        
        .inv-amount-words-title {
            font-size: 10px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: var(--text-muted);
        }

        .inv-totals-table {
            width: 320px;
        }

        .inv-totals-row {
            display: flex;
            justify-content: space-between;
            padding: 8px 0;
            font-size: 14px;
            color: var(--text-secondary);
        }

        .inv-totals-row .amount {
            color: var(--text-primary);
            font-variant-numeric: tabular-nums;
            font-weight: 500;
        }

        .inv-totals-row.grand {
            margin-top: 8px;
            padding-top: 16px;
            border-top: 1px solid var(--border-strong);
            font-size: 16px;
            font-weight: 600;
            color: var(--text-primary);
        }

        .inv-totals-row.grand .amount {
            font-size: 24px;
            font-weight: 800;
            letter-spacing: -0.5px;
        }

        .inv-totals-row.received {
            color: var(--accent);
            font-weight: 500;
        }
        .inv-totals-row.received .amount { color: var(--accent); font-weight: 600; }

        .inv-totals-row.balance {
            color: #b91c1c;
            font-weight: 600;
            padding: 12px 16px;
            background: #fef2f2;
            border-radius: 8px;
            margin-top: 8px;
        }
        .inv-totals-row.balance .amount { color: #b91c1c; font-weight: 700; }

        .inv-footer {
            padding: 32px 48px;
            background: #f8fafc;
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
            border-top: 1px solid var(--border-strong);
        }

        .inv-footer-note {
            font-size: 12px;
            color: var(--text-secondary);
        }

        .inv-footer-brand {
            font-size: 12px;
            font-weight: 600;
            color: var(--text-muted);
            margin-top: 8px;
        }

        .inv-footer-brand span { color: var(--accent); }

        .inv-sign-block { text-align: right; }

        .inv-sign-line {
            width: 160px;
            height: 1px;
            background: var(--text-muted);
            margin: 0 0 12px auto;
        }

        .inv-sign-label {
            font-size: 11px;
            font-weight: 600;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        /* ── FAB Print ── */
        .fab-print {
            position: fixed;
            bottom: 28px;
            right: 28px;
            z-index: 50;
        }

        .fab-print button {
            border: none;
            padding: 14px 26px;
            border-radius: 999px;
            display: inline-flex;
            align-items: center;
            gap: 10px;
            background: var(--accent);
            color: #fff;
            font-size: 14px;
            font-weight: 600;
            box-shadow: 0 8px 24px rgba(79, 70, 229, 0.4);
            cursor: pointer;
            font-family: 'Inter', sans-serif;
            transition: transform 0.2s, box-shadow 0.2s;
        }

        .fab-print button:hover {
            transform: translateY(-2px);
            box-shadow: 0 12px 28px rgba(79, 70, 229, 0.5);
        }

        @media print {
            body {
                background: #fff;
            }

            .os-page,
            .inv-page {
                padding: 0;
                max-width: 100%;
            }

            .os-card,
            .inv-doc,
            .premium-card {
                box-shadow: none;
                border: none;
                margin: 0;
            }
            .scaled-viewport {
                display: block;
            }
            .scaled-content {
                transform: none !important;
                width: 100% !important;
                margin: 0 !important;
                padding: 0 !important;
            }

            .fab-print {
                display: none;
            }
        }

        /* Removed media max-width 640px to enable proper scaled preview */
    </style>
</head>

<body>
    <!-- Loader -->
    <div id="loader" class="loader-wrap">
        <div class="spinner"></div>
        <div class="loader-text">Loading details…</div>
        <div class="loader-sub">Fetching your receipt securely</div>
    </div>

    <!-- Error -->
    <div id="error-screen" class="error-wrap">
        <div class="error-icon">⚠️</div>
        <h2 class="error-title" id="error-title">Receipt Not Found</h2>
        <p class="error-desc" id="error-message">The receipt link is invalid or data is unavailable.</p>
        <button class="btn-retry" onclick="window.location.reload()">Try Again</button>
    </div>

    <!-- Main content (injected by JS) -->
    <div id="content-wrap"></div>

    <!-- FAB -->
    <div class="fab-print" id="fabPrint" style="display:none;">
        <button type="button" onclick="window.print()">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                stroke-linecap="round" stroke-linejoin="round">
                <polyline points="6 9 6 2 18 2 18 9" />
                <path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2" />
                <rect x="6" y="14" width="12" height="8" />
            </svg>
            Download / Print
        </button>
    </div>

    <script>
        const API_BASE = window.location.hostname === 'localhost' || window.location.hostname === '127.0.0.1'
            ? 'http://localhost:8000'
            : window.location.origin;

        // ── helpers ──────────────────────────────────────────────────────────
        const $ = id => document.getElementById(id);
        const hide = id => { const el = $(id); if (el) el.style.display = 'none'; };
        const show = id => { const el = $(id); if (el) el.style.display = 'block'; };

        const fmtMoney = v => '₹' + Number(v || 0).toLocaleString('en-IN', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
        const fmtDate = raw => {
            if (!raw) return '—';
            try {
                let d;
                if (/^\d{2}-\d{2}-\d{4}$/.test(raw)) {
                    const [dd, mm, yyyy] = raw.split('-');
                    d = new Date(`${yyyy}-${mm}-${dd}`);
                } else {
                    d = new Date(raw);
                }
                if (isNaN(d)) return raw;
                return d.toLocaleDateString('en-IN', { day: '2-digit', month: 'short', year: 'numeric' });
            } catch { return raw; }
        };

        function showError(title, msg) {
            hide('loader');
            const el = $('error-screen');
            if (el) { el.style.display = 'flex'; }
            if (title) $('error-title').textContent = title;
            if (msg) $('error-message').textContent = msg;
        }

        function numberToWords(n) {
            const ones = ['', 'One', 'Two', 'Three', 'Four', 'Five', 'Six', 'Seven', 'Eight', 'Nine', 'Ten', 'Eleven', 'Twelve',
                'Thirteen', 'Fourteen', 'Fifteen', 'Sixteen', 'Seventeen', 'Eighteen', 'Nineteen'];
            const tens = ['', '', 'Twenty', 'Thirty', 'Forty', 'Fifty', 'Sixty', 'Seventy', 'Eighty', 'Ninety'];
            if (n === 0) return 'Zero';
            function below1000(num) {
                if (num < 20) return ones[num];
                if (num < 100) return tens[Math.floor(num / 10)] + (num % 10 ? ' ' + ones[num % 10] : '');
                return ones[Math.floor(num / 100)] + ' Hundred' + (num % 100 ? ' ' + below1000(num % 100) : '');
            }
            let result = '';
            const crore = Math.floor(n / 10000000); n %= 10000000;
            const lakh = Math.floor(n / 100000); n %= 100000;
            const thousand = Math.floor(n / 1000); n %= 1000;
            const rest = n;
            if (crore) result += below1000(crore) + ' Crore ';
            if (lakh) result += below1000(lakh) + ' Lakh ';
            if (thousand) result += below1000(thousand) + ' Thousand ';
            if (rest) result += below1000(rest);
            return result.trim();
        }

        // ── main ─────────────────────────────────────────────────────────────
        async function fetchAndRender() {
            const params = new URLSearchParams(window.location.search);
            
            // Support 'i' or 'id' for orderId
            let orderId = params.get('i') || params.get('id');
            if (!orderId) {
                const m = window.location.search.match(/[?&](?:id|i)(?:=|%3D)([^&]+)/i);
                if (m) orderId = decodeURIComponent(m[1]);
            }
            if (!orderId) { showError('Invalid Link', 'No receipt ID found in URL.'); return; }

            // Support 'g' or 'gst_mode'
            const gstMode = params.get('g') || params.get('gst_mode') || 'none'; // none | included | excluded
            
            const uParam = params.get('u'); // username

            try {
                let apiUrl = `${API_BASE}/api/public/receipts/${orderId}`;
                if (uParam) {
                    apiUrl += `?u=${encodeURIComponent(uParam)}`;
                }
                const resp = await fetch(apiUrl);
                if (!resp.ok) throw new Error(resp.status === 404 ? 'not_found' : 'server_error');
                const data = await resp.json();

                // Support 'p' or 'pm' for payment_mode
                if (params.has('p')) data.payment_mode = params.get('p');
                else if (params.has('pm')) data.payment_mode = params.get('pm');

                // Support 'r' or 'ra' for received_amount
                if (params.has('r')) data.received_amount = Number(params.get('r'));
                else if (params.has('ra')) data.received_amount = Number(params.get('ra'));

                // Support 'b' or 'bd' for balance_due
                if (params.has('b')) data.balance_due = Number(params.get('b'));
                else if (params.has('bd')) data.balance_due = Number(params.get('bd'));

                if (gstMode === 'none') {
                    renderOrderSummary(data);
                } else {
                    renderGstInvoice(data, gstMode);
                }
            } catch (err) {
                if (err.message === 'not_found') showError('Receipt Not Found', 'We could not locate this receipt.');
                else showError('Unable to Load', 'Please check your connection and try again.');
            }
        }

        // ─────────────────────────────────────────────────────────────────────
        // ORDER SUMMARY renderer
        // ─────────────────────────────────────────────────────────────────────
        function renderOrderSummary(data) {
            document.title = `Order Summary #${data.id || '—'} • SnapKhata`;

            const items = Array.isArray(data.items) ? data.items : [];
            const isPaid = data.status === 'PAID';

            // Separate taxable (parts) and non-taxable (labor) items
            const taxableItems = items.filter(i => {
                const t = String(i.type || '').toLowerCase();
                return t !== 'labor' && t !== 'labour' && t !== 'service';
            });
            const nonTaxableItems = items.filter(i => {
                const t = String(i.type || '').toLowerCase();
                return t === 'labor' || t === 'labour' || t === 'service';
            });

            // Calculate subtotals
            const partsSubtotal = taxableItems.reduce((s, i) => s + Number(i.amount || 0), 0);
            const laborSubtotal = nonTaxableItems.reduce((s, i) => s + Number(i.amount || 0), 0);

            // Grand Total (since no GST)
            const subtotal = items.reduce((s, i) => s + Number(i.amount || 0), 0);
            const grandTotal = Number(data.total_amount) || subtotal;

            let itemsHtml = '';

            // Parts
            if (taxableItems.length > 0) {
                itemsHtml += `<tr><td colspan="5" style="background:#f8fafc;padding:8px 14px;font-size:11px;font-weight:700;color:#0f172a;text-transform:uppercase;letter-spacing:0.5px;">Spare Parts</td></tr>`;
                taxableItems.forEach((item, idx) => {
                    const qty = Number(item.qty || 1);
                    const rate = Number(item.rate || 0);
                    const amount = Number(item.amount || 0);

                    itemsHtml += `
                    <tr>
                        <td class="center">${idx + 1}</td>
                        <td>${item.name || 'Spare Part'}</td>
                        <td class="center">${qty}</td>
                        <td class="right">${fmtMoney(rate > 0 ? rate : amount / qty)}</td>
                        <td class="right" style="font-weight:700;">${fmtMoney(amount)}</td>
                    </tr>`;
                });
            }

            // Labor
            if (nonTaxableItems.length > 0) {
                if (taxableItems.length > 0) {
                    itemsHtml += `<tr><td colspan="5" style="height:8px;"></td></tr>`;
                }
                itemsHtml += `<tr><td colspan="5" style="background:#f8fafc;padding:8px 14px;font-size:11px;font-weight:700;color:#64748b;text-transform:uppercase;letter-spacing:0.5px;">Servicing</td></tr>`;
                nonTaxableItems.forEach((item, idx) => {
                    const qty = Number(item.qty || 1);
                    const rate = Number(item.rate || 0);
                    const amount = Number(item.amount || 0);

                    itemsHtml += `
                    <tr>
                        <td class="center">${idx + 1}</td>
                        <td>${item.name || 'Servicing'}</td>
                        <td class="center">${qty}</td>
                        <td class="right">${fmtMoney(rate > 0 ? rate : amount / qty)}</td>
                        <td class="right" style="font-weight:700;">${fmtMoney(amount)}</td>
                    </tr>`;
                });
            }

            if (items.length === 0) {
                itemsHtml = `<tr><td colspan="5" style="text-align:center;padding:32px;color:#94a3b8;">No line items for this receipt.</td></tr>`;
            }

            const wordsTotal = numberToWords(Math.round(grandTotal));

            const html = `
            <div class="scaled-container">
                <div class="inv-page">
                    <div class="inv-doc">
                        <div class="inv-shop-header">
                            <div>
                                <span class="inv-doc-type">Order Summary</span>
                                <div class="inv-shop-name">${data.shop_name || 'Business Name'}</div>
                                ${(data.shop_address || data.shop_phone) ? `
                                <div class="inv-shop-detail">
                                    ${data.shop_address ? `${data.shop_address}<br>` : ''}
                                    ${data.shop_phone ? `+91 ${String(data.shop_phone).replace('+91', '').trim()}` : ''}
                                </div>` : ''}
                            </div>
                            <div class="inv-badge-container">
                                <div>
                                    <span class="inv-status-pill ${isPaid ? 'inv-paid' : 'inv-pending'}">
                                        ${(isPaid && data.payment_mode === 'Credit') ? 'PARTIAL' : (isPaid ? 'PAID' : 'PENDING')}
                                    </span>
                                </div>
                            </div>
                        </div>

                        <div class="inv-details-row">
                            <div class="inv-details-grid">
                                <div>
                                    <div class="inv-col-label">Order Details</div>
                                    <div class="inv-col-val">
                                        <div><strong>Order No:</strong> #${data.id || '—'}</div>
                                        <div><strong>Date:</strong> ${fmtDate(data.created_at)}</div>
                                    </div>
                                </div>
                                <div>
                                    <div class="inv-col-label">Bill To</div>
                                    <div class="inv-col-val">
                                        <div><strong>${data.customer_name || 'Walk-in Customer'}</strong></div>
                                        ${data.customer_phone ? `<div>+91 ${String(data.customer_phone).replace('+91', '').trim()}</div>` : ''}
                                        ${data.vehicle_number ? `<div style="margin-top:4px;"><strong>Vehicle:</strong> ${data.vehicle_number}</div>` : ''}
                                        ${data.odometer_reading ? `<div><strong>Odometer:</strong> ${data.odometer_reading} km</div>` : ''}
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="inv-table-container">
                            <table class="inv-table">
                                <thead>
                                    <tr>
                                        <th class="center" style="width:5%">#</th>
                                        <th style="width:45%">Description</th>
                                        <th class="center" style="width:10%">Qty</th>
                                        <th class="right" style="width:20%">Rate</th>
                                        <th class="right" style="width:20%">Total</th>
                                    </tr>
                                </thead>
                                <tbody>${itemsHtml}</tbody>
                            </table>
                        </div>

                        <div class="inv-totals-wrap">
                            <div>
                                <div class="inv-amount-words-title">Amount in Words</div>
                                <div class="inv-amount-words">Rupees ${wordsTotal} Only</div>
                                ${laborSubtotal > 0.01 ? `<div style="font-size:11px;color:#64748b;margin-top:12px;">Spare Parts: ${fmtMoney(partsSubtotal)} &nbsp;|&nbsp; Servicing: ${fmtMoney(laborSubtotal)}</div>` : ''}
                            </div>
                            <div class="inv-totals-table">
                                ${partsSubtotal > 0.01 && laborSubtotal > 0.01 ? `
                                <div class="inv-totals-row">
                                    <span class="label">Spare Parts</span>
                                    <span class="amount">${fmtMoney(partsSubtotal)}</span>
                                </div>
                                <div class="inv-totals-row">
                                    <span class="label">Servicing</span>
                                    <span class="amount">${fmtMoney(laborSubtotal)}</span>
                                </div>
                                ` : ''}
                                <div class="inv-totals-row grand">
                                    <span class="label">Total Amount</span>
                                    <span class="amount">${fmtMoney(grandTotal)}</span>
                                </div>
                            </div>
                        </div>

                        <div class="inv-footer">
                            <div>
                                <div class="inv-footer-note">This is a digital order summary and does not require a signature.</div>
                                <div class="inv-footer-brand">Powered by <span>SnapKhata</span></div>
                            </div>
                            <div class="inv-sign-block">
                                <div class="inv-sign-line"></div>
                                <div class="inv-sign-label">Authorised Signature</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>`;\n\n            $('content-wrap').innerHTML = html;
            $('content-wrap').style.display = 'block';
            $('fabPrint').style.display = 'block';
            hide('loader');
        }

        // ─────────────────────────────────────────────────────────────────────
        // GST INVOICE renderer
        // ─────────────────────────────────────────────────────────────────────
        function renderGstInvoice(data, gstMode) {
            document.title = `Tax Invoice #${data.id || '—'} • SnapKhata`;

            const items = Array.isArray(data.items) ? data.items : [];
            const isPaid = data.status === 'PAID';

            // Separate taxable (parts) and non-taxable (labor) items
            const taxableItems = items.filter(i => {
                const t = String(i.type || '').toLowerCase();
                return t !== 'labor' && t !== 'labour' && t !== 'service';
            });
            const nonTaxableItems = items.filter(i => {
                const t = String(i.type || '').toLowerCase();
                return t === 'labor' || t === 'labour' || t === 'service';
            });

            // Calculate subtotals
            const partsSubtotal = taxableItems.reduce((s, i) => s + Number(i.amount || 0), 0);
            const laborSubtotal = nonTaxableItems.reduce((s, i) => s + Number(i.amount || 0), 0);

            // GST calculation (only on parts)
            let gstAmt, grandTotal;
            if (gstMode === 'included') {
                gstAmt = partsSubtotal * 18 / 118;
                grandTotal = partsSubtotal + laborSubtotal; // total unchanged
            } else { // excluded
                gstAmt = partsSubtotal * 0.18;
                grandTotal = partsSubtotal + gstAmt + laborSubtotal;
            }

            const taxableValue = gstMode === 'included'
                ? partsSubtotal - gstAmt   // base without GST
                : partsSubtotal;           // already net

            // Build items HTML with Part/Labor labels
            let itemsHtml = '';

            // Taxable items (Parts)
            if (taxableItems.length > 0) {
                itemsHtml += `<tr><td colspan="8" style="background:#f8fafc;padding:8px 14px;font-size:11px;font-weight:700;color:#0f172a;text-transform:uppercase;letter-spacing:0.5px;">Spare Parts (Taxable @ 18%)</td></tr>`;
                taxableItems.forEach((item, idx) => {
                    const qty = Number(item.qty || 1);
                    const rate = Number(item.rate || 0);
                    const amount = Number(item.amount || 0);
                    // In 'included' mode, back-calculate the taxable unit rate
                    const baseAmt = gstMode === 'included' ? amount * 100 / 118 : amount;
                    const baseRate = gstMode === 'included' ? (rate > 0 ? rate * 100 / 118 : baseAmt / qty) : (rate > 0 ? rate : amount / qty);

                    itemsHtml += `
                    <tr>
                        <td class="center">${idx + 1}</td>
                        <td>${item.name || 'Spare Part'}</td>
                        <td class="center">${qty}</td>
                        <td class="right">${fmtMoney(baseRate)}</td>
                        <td class="right">${fmtMoney(baseAmt)}</td>
                        <td class="center" style="color:#d97706;font-weight:600;">18%</td>
                        <td class="right" style="color:#d97706;font-weight:600;">${fmtMoney(baseAmt * 0.18)}</td>
                        <td class="right" style="font-weight:700;">${fmtMoney(baseAmt * 1.18)}</td>
                    </tr>`;
                });
            }

            // Non-taxable items (Labor)
            if (nonTaxableItems.length > 0) {
                if (taxableItems.length > 0) {
                    itemsHtml += `<tr><td colspan="8" style="height:8px;"></td></tr>`;
                }
                itemsHtml += `<tr><td colspan="8" style="background:#f8fafc;padding:8px 14px;font-size:11px;font-weight:700;color:#64748b;text-transform:uppercase;letter-spacing:0.5px;">Servicing (No GST)</td></tr>`;
                nonTaxableItems.forEach((item, idx) => {
                    const qty = Number(item.qty || 1);
                    const rate = Number(item.rate || 0);
                    const amount = Number(item.amount || 0);

                    itemsHtml += `
                    <tr>
                        <td class="center">${idx + 1}</td>
                        <td>${item.name || 'Servicing'}</td>
                        <td class="center">${qty}</td>
                        <td class="right">${fmtMoney(rate > 0 ? rate : amount / qty)}</td>
                        <td class="right">${fmtMoney(amount)}</td>
                        <td class="center" style="color:#94a3b8;">—</td>
                        <td class="right" style="color:#94a3b8;">—</td>
                        <td class="right" style="font-weight:700;">${fmtMoney(amount)}</td>
                    </tr>`;
                });
            }

            if (items.length === 0) {
                itemsHtml = `<tr><td colspan="8" style="text-align:center;padding:32px;color:#94a3b8;">No line items for this receipt.</td></tr>`;
            }

            const wordsTotal = numberToWords(Math.round(grandTotal));
            const cgst = gstAmt / 2;
            const sgst = gstAmt / 2;

            const html = `
            <div class="scaled-container">
                <div class="inv-page">
                    <div class="inv-doc">
                        <div class="inv-shop-header">
                            <div>
                                <span class="inv-doc-type">Tax Invoice</span>
                                <div class="inv-shop-name">${data.shop_name || 'Business Name'}</div>
                                ${(data.shop_address || data.shop_phone) ? `
                                <div class="inv-shop-detail">
                                    ${data.shop_address ? `${data.shop_address}<br>` : ''}
                                    ${data.shop_phone ? `+91 ${String(data.shop_phone).replace('+91', '').trim()}` : ''}
                                </div>` : ''}
                            </div>
                            <div class="inv-badge-container">
                                ${data.shop_gst ? `
                                <div>
                                    <div class="inv-col-label" style="margin-bottom:2px">GSTIN</div>
                                    <div class="inv-gst-number">${data.shop_gst}</div>
                                </div>
                                ` : ''}
                                <div>
                                    <span class="inv-status-pill ${isPaid ? 'inv-paid' : 'inv-pending'}">
                                        ${(isPaid && data.payment_mode === 'Credit') ? 'PARTIAL' : (isPaid ? 'PAID' : 'PENDING')}
                                    </span>
                                </div>
                            </div>
                        </div>

                        <div class="inv-details-row">
                            <div class="inv-details-grid">
                                <div>
                                    <div class="inv-col-label">Invoice Details</div>
                                    <div class="inv-col-val">
                                        <div><strong>Invoice No:</strong> #${data.id || '—'}</div>
                                        <div><strong>Date:</strong> ${fmtDate(data.created_at)}</div>
                                        <div style="margin-top:6px;font-size:11px;color:#64748b;">GST @18% on Parts ${gstMode === 'included' ? '(Included inside Rate)' : '(Excluded)'}</div>
                                    </div>
                                </div>
                                <div>
                                    <div class="inv-col-label">Bill To</div>
                                    <div class="inv-col-val">
                                        <div><strong>${data.customer_name || 'Walk-in Customer'}</strong></div>
                                        ${data.customer_phone ? `<div>+91 ${String(data.customer_phone).replace('+91', '').trim()}</div>` : ''}
                                        ${data.vehicle_number ? `<div style="margin-top:4px;"><strong>Vehicle:</strong> ${data.vehicle_number}</div>` : ''}
                                        ${data.odometer_reading ? `<div><strong>Odometer:</strong> ${data.odometer_reading} km</div>` : ''}
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="inv-table-container">
                            <table class="inv-table">
                                <thead>
                                    <tr>
                                        <th class="center" style="width:4%">#</th>
                                        <th style="width:36%">Description</th>
                                        <th class="center" style="width:6%">Qty</th>
                                        <th class="right" style="width:14%">Base Rate</th>
                                        <th class="right" style="width:14%">Base Amt</th>
                                        <th class="right" style="width:11%">GST</th>
                                        <th class="right" style="width:15%">Total</th>
                                    </tr>
                                </thead>
                                <tbody>${itemsHtml}</tbody>
                            </table>
                        </div>

                        <div class="inv-totals-wrap">
                            <div>
                                <div class="inv-amount-words-title">Amount in Words</div>
                                <div class="inv-amount-words">Rupees ${wordsTotal} Only</div>
                                ${laborSubtotal > 0.01 ? `<div style="font-size:11px;color:#64748b;margin-top:12px;">Spare Parts: ${fmtMoney(partsSubtotal)} &nbsp;|&nbsp; Servicing: ${fmtMoney(laborSubtotal)}</div>` : ''}
                            </div>
                            <div class="inv-totals-table">
                                <div class="inv-totals-row">
                                    <span class="label">Taxable Amount (Parts)</span>
                                    <span class="amount">${fmtMoney(taxableValue)}</span>
                                </div>
                                <div class="inv-totals-row" style="color:#475569;">
                                    <span class="label">CGST @9%</span>
                                    <span class="amount">${fmtMoney(cgst)}</span>
                                </div>
                                <div class="inv-totals-row" style="color:#475569;">
                                    <span class="label">SGST @9%</span>
                                    <span class="amount">${fmtMoney(sgst)}</span>
                                </div>
                                ${laborSubtotal > 0.01 ? `
                                <div class="inv-totals-row" style="margin-top:4px;">
                                    <span class="label">Servicing (No GST)</span>
                                    <span class="amount">${fmtMoney(laborSubtotal)}</span>
                                </div>
                                ` : ''}
                                <div class="inv-totals-row grand">
                                    <span class="label">Grand Total</span>
                                    <span class="amount">${fmtMoney(grandTotal)}</span>
                                </div>
                            </div>
                        </div>

                        <div class="inv-footer">
                            <div>
                                <div class="inv-footer-note">This is a computer-generated invoice and does not require a signature.</div>
                                <div class="inv-footer-brand">Powered by <span>SnapKhata</span></div>
                            </div>
                            <div class="inv-sign-block">
                                <div class="inv-sign-line"></div>
                                <div class="inv-sign-label">Authorised Signature</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>`;\n\n            $('content-wrap').innerHTML = html;
            $('content-wrap').style.display = 'block';
            $('fabPrint').style.display = 'block';
            hide('loader');
        }

        async function init() {
            await fetchAndRender();
        }

        document.addEventListener('DOMContentLoaded', init);
    </script>
</body>

</html>