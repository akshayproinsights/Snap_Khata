# [Snap_Khata] Git Ignore Patterns

# Environments
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
**/.env
**/.env.*
!**/.env.example

# Python
backend/venv/
backend/.venv/
venv/
.venv/
ENV/
env/
__pycache__/
*.py[cod]
*$py.class

# Node / React
node_modules/
frontend/node_modules/
dist/
frontend/dist/
build/
frontend/build/
.npm
/root/Snap_Khata/frontend/build

# Flutter / Dart
.dart_tool/
.packages
.pub-cache/
.pub/
build/
mobile/build/
mobile/.dart_tool/
mobile/.packages
mobile/.pub/
mobile/*.freezed.dart
mobile/*.g.dart

# IDEs / Editors
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Other
cloud_run_env.json
.stitch/
firebase-debug.log
.firebase/

# Log files
*.log
logs/

