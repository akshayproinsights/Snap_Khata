# Backend Environment Variables for Local Development
# Copy this to .env and fill in the values

# Supabase Configuration (Use Dev Database credentials)
SUPABASE_URL=your_supabase_url
SUPABASE_KEY=your_supabase_anon_key
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Cloudflare R2 Configuration (From secrets.toml)
R2_ACCOUNT_ID=your_r2_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_PUBLIC_BASE_URL=your_r2_public_base_url

# Google API Key
GOOGLE_API_KEY=your_google_api_key

# Users Config (Base64 encoded JSON of users from secrets.toml)
# You can generate this by running: echo -n '{"users": {...}}' | base64
USERS_CONFIG_JSON_BASE64=
GCP_SERVICE_ACCOUNT_JSON_BASE64=
